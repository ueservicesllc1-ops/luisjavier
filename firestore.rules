rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if the user has admin/photographer email
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "ueservicesllc1@gmail.com" ||
        request.auth.token.email == "cliente@demo.com"
      );
    }

    // Clientes: anyone authenticated can read (needed for PIN lookup), only admin can write
    match /clients/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // Sesiones: authenticated can read, only admin can write
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // Fotos: authenticated users can read, only admin can write
    match /photos/{photoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // Videos: authenticated users can read, only admin can write
    match /videos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
  }
}
